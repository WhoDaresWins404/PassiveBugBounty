# ==========================================
# APPLICATION & LOGGING
# ==========================================
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# ==========================================
# POSTGRESQL (Metadata & Audit Logs)
# ==========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=analyzer_db
POSTGRES_USER=analyzer_user
POSTGRES_PASSWORD=lab2

# ==========================================
# REDIS (Buffer & Prioritization Queue)
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD= # Uncomment if you set a Redis password

# ==========================================
# TRAFFIC INGRESS (mitmproxy)
# ==========================================
# Port the mitmproxy addon will listen on
MITMPROXY_LISTEN_PORT=8080

# P0 Constraint: Pre-approved targets only (comma-separated)
# Prevents accidental analysis of unauthorized traffic
ALLOWED_TARGETS=example.com,test.local,192.168.1.100

# P0 Constraint: Data Minimization
# Max body size to process (in bytes). 1048576 = 1MB. 
# Bodies exceeding this are truncated or skipped unless flagged.
MAX_BODY_SIZE_BYTES=1048576

# ==========================================
# STORAGE & RETENTION
# ==========================================
# Directory for the unstructured JSON-lines traffic pool
UNSTRUCTURED_POOL_DIR=/var/log/analyzer/unstructured

# P0 Constraint: Auto-expire TTL for unstructured pool (in hours)
UNSTRUCTURED_TTL_HOURS=72

# ==========================================
# SECURITY & CONSTRAINTS
# ==========================================
# P0 Constraint: Strict passive mode. If True, the code will 
# actively block/raise errors on any attempt to make outbound HTTP calls.
STRICT_PASSIVE_MODE=True