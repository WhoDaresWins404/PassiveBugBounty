# src/storage/db_init.py
import asyncio
import asyncpg
from src.config import settings

async def init_db():
    """Initialize PostgreSQL with the minimal safe storage schema."""
    conn = await asyncpg.connect(settings.postgres_url)
    
    try:
        # Create sessions metadata table
        await conn.execute("""
            CREATE TABLE IF NOT EXISTS http_sessions (
                correlation_id UUID PRIMARY KEY,
                timestamp TIMESTAMPTZ NOT NULL,
                host VARCHAR(255) NOT NULL,
                method VARCHAR(10) NOT NULL,
                path TEXT NOT NULL,
                request_headers JSONB,
                response_status INT,
                response_headers JSONB,
                request_content_length INT,
                response_content_length INT,
                is_suspicious BOOLEAN DEFAULT FALSE,
                created_at TIMESTAMPTZ DEFAULT CURRENT_TIMESTAMP
            );
        """)
        
        # Create index for faster querying by host or suspicious flag
        await conn.execute("""
            CREATE INDEX IF NOT EXISTS idx_sessions_host 
            ON http_sessions(host);
            CREATE INDEX IF NOT EXISTS idx_sessions_suspicious 
            ON http_sessions(is_suspicious) WHERE is_suspicious = TRUE;
        """)
        print("✅ PostgreSQL schema initialized successfully.")
    finally:
        await conn.close()

if __name__ == "__main__":
    asyncio.run(init_db())